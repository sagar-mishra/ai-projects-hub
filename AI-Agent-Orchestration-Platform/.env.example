# ====================================================================
# Pika Orchestrator - Environment Configurations (Template)
# Copy this file to '.env' and fill in your actual credentials.
# ====================================================================

# 1. LLM API Configurations
# Groq Cloud API Key (Get a free API key at: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
DEFAULT_MODEL=llama-3.1-8b-instant

# OPTIONAL: Use local Ollama instance instead of Groq
# OLLAMA_BASE_URL=http://localhost:11434
# DEFAULT_MODEL=llama3

# 2. Telegram Messaging Channel Configurations
# Create a bot via @BotFather on Telegram and copy the API token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Expose localhost port (e.g. 8000/8001) using a tunnel like ngrok:
#   ngrok http 8001
# Set the generated HTTPS tunnel URL here to register the bot webhook:
TELEGRAM_WEBHOOK_URL=https://your-ngrok-subdomain.ngrok-free.dev

# 3. Application Configurations
DATABASE_URL=sqlite:///./platform.db
SECRET_KEY=generate_a_random_32_character_string_for_production_security
BACKEND_PORT=8001
BACKEND_URL=http://localhost:8001
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# 4. Safety Guardrail Options
# Hard stop cost limits for a single graph execution path run
MAX_RUN_COST_USD=0.10
